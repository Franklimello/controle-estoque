# Configura횄짠횄쨉es do Firebase
# Copie este arquivo para .env e preencha com suas credenciais do Firebase
# 
# Para obter as credenciais:
# 1. Acesse: https://console.firebase.google.com/
# 2. Selecione seu projeto
# 3. V횄징 em Configura횄짠횄쨉es do projeto (횄짯cone de engrenagem)
# 4. Role at횄짤 "Seus aplicativos" e copie as credenciais

VITE_FIREBASE_API_KEY=sua-api-key-aqui
VITE_FIREBASE_AUTH_DOMAIN=seu-project-id.firebaseapp.com
VITE_FIREBASE_PROJECT_ID=seu-project-id
VITE_FIREBASE_STORAGE_BUCKET=seu-project-id.firebasestorage.app
VITE_FIREBASE_MESSAGING_SENDER_ID=seu-messaging-sender-id
VITE_FIREBASE_APP_ID=seu-app-id

# Opcional para script de manutencao (backfill de codigos):
# GCLOUD_PROJECT=seu-project-id
# GOOGLE_APPLICATION_CREDENTIALS=C:\caminho\service-account.json
# ou FIREBASE_SERVICE_ACCOUNT_JSON={"type":"service_account", ...}
